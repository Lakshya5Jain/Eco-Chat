# ── Required ──────────────────────────────────────────────────────────────────

# FRED API key — get one free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Optional (safe defaults are used if omitted) ─────────────────────────────

# LLM model to use for the agent (default: gpt-5.4)
# OPENAI_MODEL=gpt-5.4

# Max seconds to wait for an OpenAI response before timing out (default: 60)
# OPENAI_REQUEST_TIMEOUT_SECONDS=60

# Max tool-call loops the ReAct agent can execute per query (default: 25)
# Prevents runaway loops on ambiguous or adversarial input
# AGENT_RECURSION_LIMIT=25

# Socket timeout in seconds for FRED API requests (default: 15)
# fredapi has no built-in timeout — this is enforced via a monkey-patch
# FRED_HTTP_TIMEOUT_SECONDS=15
